OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Backward-compatible fallback model
OPENROUTER_MODEL=openai/gpt-4o-mini

# Summary bot model (URL summary)
OPENROUTER_SUMMARY_MODEL=openai/gpt-4o-mini

# Knowledge QA model (RAG answer)
OPENROUTER_KNOWLEDGE_MODEL=openai/gpt-4o-mini

HTTP_TIMEOUT_SECONDS=15

# RAG Service (news-rag-db/rag-service) 연동
# 미설정 시 지식 기능 비활성 (요약봇은 정상 동작)
RAG_SERVICE_URL=http://localhost:8000

# Optional prompt override (use \n for line breaks)
# SUMMARY_SYSTEM_PROMPT=...
# SUMMARY_USER_PROMPT_TEMPLATE=...
# BUDDHA_SYSTEM_PROMPT=...
# BUDDHA_USER_PROMPT_TEMPLATE=...
# KNOWLEDGE_QA_SYSTEM_PROMPT=...
# KNOWLEDGE_QA_USER_PROMPT_TEMPLATE=...
